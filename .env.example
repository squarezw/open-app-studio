# LLM provider for AI features (component generation, annotator).
# Any OpenAI-compatible chat-completions endpoint works: DeepSeek, OpenAI, Ollama, vLLM…
OAS_LLM_API_KEY=
OAS_LLM_BASE_URL=https://api.deepseek.com
OAS_LLM_MODEL=deepseek-chat

# Vision LLM for screenshot analysis (entry/first-screen detection). Optional —
# any OpenAI-compatible vision endpoint (Qwen-VL via DashScope, GPT-4o, …).
OAS_VLM_API_KEY=
OAS_VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OAS_VLM_MODEL=qwen-vl-max

# Android SDK — lets the gateway find adb without shell PATH setup.
# (or set OAS_ADB_PATH to the adb binary directly)
ANDROID_HOME=
# AVD to auto-boot when an adb run finds no device (else the first listed AVD).
OAS_ANDROID_AVD=oas-test

