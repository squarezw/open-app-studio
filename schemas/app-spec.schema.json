{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openappstudio.dev/schemas/app-spec.schema.json",
  "title": "App Spec",
  "description": "The buildable app definition: screens, components, navigation, and data. Produced by the canvas, the AI sidebar, or the Blueprint Compiler; consumed by codegen.",
  "type": "object",
  "required": ["version", "app", "navigation", "screens"],
  "properties": {
    "version": { "const": "0.1" },
    "app": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "appId": { "type": "string", "description": "bundle id / package name for the generated app" },
        "theme": { "$ref": "#/$defs/themeTokens" }
      }
    },
    "navigation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "initial"],
          "properties": {
            "type": { "const": "stack" },
            "initial": { "type": "string", "description": "screen id" }
          }
        },
        {
          "type": "object",
          "required": ["type", "tabs"],
          "properties": {
            "type": { "const": "tabs" },
            "tabs": {
              "type": "array",
              "minItems": 2,
              "maxItems": 5,
              "items": {
                "type": "object",
                "required": ["id", "screenId", "label"],
                "properties": {
                  "id": { "type": "string" },
                  "screenId": { "type": "string" },
                  "label": { "type": "string" },
                  "icon": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "components"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "title": { "type": "string" },
          "role": { "type": "string" },
          "components": { "type": "array", "items": { "$ref": "#/$defs/componentInstance" } }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "fields"],
            "properties": {
              "name": { "type": "string" },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "type"],
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "enum": ["string", "int", "float", "boolean", "date", "url", "image"] },
                    "required": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "generatedFrom": { "enum": ["ifg", "canvas", "ai"] },
        "sourceRunId": { "type": "string" },
        "sourceStoreUrl": { "type": "string" },
        "sourceNodeIds": {
          "type": "object",
          "description": "screen id → originating IFG node id (provenance)",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "componentInstance": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$", "description": "registry ref, e.g. oas/list" },
        "props": { "type": "object" },
        "slots": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/componentInstance" }
          }
        }
      }
    },
    "themeTokens": {
      "type": "object",
      "properties": {
        "colors": { "type": "object", "additionalProperties": { "type": "string" } },
        "spacing": { "type": "object", "additionalProperties": { "type": "number" } },
        "radii": { "type": "object", "additionalProperties": { "type": "number" } },
        "typography": { "type": "object" }
      }
    }
  }
}
